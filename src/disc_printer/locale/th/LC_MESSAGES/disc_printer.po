#, python-format
msgid "Ø %.0f mm"
msgstr "Ø %.0f มม."

msgid "Hub · nicht bedruckbar"
msgstr "ดุม · ไม่สามารถพิมพ์ได้"

#, python-format
msgid "Ø %.0f mm  (bedruckbar)"
msgstr "Ø %.0f มม.  (พิมพ์ได้)"

msgid "Text bearbeiten"
msgstr "แก้ไขข้อความ"

msgid "Text hinzufügen"
msgstr "เพิ่มข้อความ"

msgid "Text:"
msgstr "ข้อความ:"

msgid "Schriftart wählen"
msgstr "เลือกแบบอักษร"

msgid "Schrift:"
msgstr "แบบอักษร:"

msgid "Textfarbe"
msgstr "สีข้อความ"

msgid "Farbe:"
msgstr "สี:"

msgid "Abbrechen"
msgstr "ยกเลิก"

msgid "OK"
msgstr "ตกลง"

msgid "Drucken …"
msgstr "พิมพ์ …"

msgid "Disc-Vorschau"
msgstr "ตัวอย่างแผ่นดิสก์"

msgid "Drucker"
msgstr "เครื่องพิมพ์"

msgid "Drucker:"
msgstr "เครื่องพิมพ์:"

msgid "Erkenne Drucker …"
msgstr "กำลังตรวจหาเครื่องพิมพ์ …"

msgid "Drucker neu erkennen"
msgstr "ตรวจหาเครื่องพิมพ์อีกครั้ง"

msgid "Initialisierung …"
msgstr "กำลังเริ่มต้น …"

msgid "Disc-Optionen"
msgstr "ตัวเลือกแผ่นดิสก์"

msgid "Hub-Größe:"
msgstr "ขนาดดุม:"

msgid "Hintergrund"
msgstr "พื้นหลัง"

msgid "Hintergrundfarbe"
msgstr "สีพื้นหลัง"

msgid "Zurücksetzen auf Weiß"
msgstr "รีเซ็ตเป็นสีขาว"

msgid "Bild:"
msgstr "รูปภาพ:"

msgid "Laden …"
msgstr "โหลด …"

msgid "(kein Bild)"
msgstr "(ไม่มีรูปภาพ)"

msgid "Hintergrundbild entfernen"
msgstr "ลบรูปภาพพื้นหลัง"

msgid "Tipp: Bilddatei direkt auf die Vorschau ziehen."
msgstr "เคล็ดลับ: ลากไฟล์รูปภาพไปวางบนพื้นที่ตัวอย่างโดยตรง"

msgid "Bild-Position & Zoom"
msgstr "ตำแหน่งรูปภาพและการซูม"

msgid "Zoom:"
msgstr "ซูม:"

msgid "5 mm links"
msgstr "5 มม. ซ้าย"

msgid "5 mm rechts"
msgstr "5 มม. ขวา"

msgid "5 mm oben"
msgstr "5 มม. ขึ้น"

msgid "5 mm unten"
msgstr "5 มม. ลง"

msgid "⌂ Zentrieren"
msgstr "⌂ จัดกึ่งกลาง"

msgid "Zurücksetzen"
msgstr "รีเซ็ต"

msgid "Bild ziehen = verschieben · Mausrad = Zoom"
msgstr "ลาก = เลื่อน · ล้อเมาส์ = ซูม"

msgid "Text-Elemente"
msgstr "องค์ประกอบข้อความ"

msgid "+ Hinzufügen"
msgstr "+ เพิ่ม"

msgid "Neues Text-Element hinzufügen"
msgstr "เพิ่มองค์ประกอบข้อความใหม่"

msgid "Keine Text-Elemente"
msgstr "ไม่มีองค์ประกอบข้อความ"

msgid "Klick = auswählen · Doppelklick = bearbeiten · Ziehen = verschieben"
msgstr "คลิก = เลือก · ดับเบิลคลิก = แก้ไข · ลาก = เลื่อน"

msgid "Element löschen"
msgstr "ลบองค์ประกอบ"

msgid "(Kein Disc-Drucker gefunden)"
msgstr "(ไม่พบเครื่องพิมพ์แผ่นดิสก์)"

msgid "Kein Disc-fähiger Drucker gefunden"
msgstr "ไม่พบเครื่องพิมพ์ที่รองรับแผ่นดิสก์"

msgid "Kein Disc-fähiger Drucker erkannt."
msgstr "ไม่พบเครื่องพิมพ์ที่รองรับแผ่นดิสก์"

msgid "Prüfe Status …"
msgstr "กำลังตรวจสอบสถานะ …"

msgid "Hintergrundbild wählen"
msgstr "เลือกรูปภาพพื้นหลัง"

msgid "Bilder (PNG, JPG, WEBP …)"
msgstr "รูปภาพ (PNG, JPG, WEBP …)"

msgid "Alle Dateien"
msgstr "ไฟล์ทั้งหมด"

#, python-format
msgid ""
"Bild konnte nicht geladen werden:\n"
"%s"
msgstr ""
"ไม่สามารถโหลดรูปภาพได้:\n"
"%s"

msgid "Bereit"
msgstr "พร้อม"

msgid "Deaktiviert / gestoppt"
msgstr "ปิดใช้งาน / หยุด"

msgid "Status unbekannt"
msgstr "ไม่ทราบสถานะ"

msgid "Nicht erreichbar (Timeout)"
msgstr "ไม่สามารถเข้าถึงได้ (หมดเวลา)"

#, python-format
msgid "Fehler: %s"
msgstr "ข้อผิดพลาด: %s"

msgid "Kein Drucker ausgewählt."
msgstr "ไม่ได้เลือกเครื่องพิมพ์"

msgid "Disc drucken?"
msgstr "พิมพ์แผ่นดิสก์?"

#, python-format
msgid ""
"Drucker:    %(name)s\n"
"Auflösung:  %(px)d×%(px)d px  (300 DPI)\n"
"\n"
"%(cmd)s"
msgstr ""
"เครื่องพิมพ์:  %(name)s\n"
"ความละเอียด:   %(px)d×%(px)d px  (300 DPI)\n"
"\n"
"%(cmd)s"

msgid "Drucken"
msgstr "พิมพ์"

#, python-format
msgid ""
"Render-Fehler:\n"
"%s"
msgstr ""
"ข้อผิดพลาดการเรนเดอร์:\n"
"%s"

#, python-format
msgid ""
"Druckfehler:\n"
"%s"
msgstr ""
"ข้อผิดพลาดการพิมพ์:\n"
"%s"

msgid "Timeout: Drucker antwortet nicht (>30 s)."
msgstr "หมดเวลา: เครื่องพิมพ์ไม่ตอบสนอง (>30 วินาที)"

msgid "Druckauftrag gesendet"
msgstr "ส่งงานพิมพ์แล้ว"

msgid "Druckauftrag erfolgreich in Warteschlange eingereiht."
msgstr "เพิ่มงานพิมพ์ในคิวเรียบร้อยแล้ว"
