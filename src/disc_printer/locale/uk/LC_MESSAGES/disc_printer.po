msgstr "Перевірка стану …"

msgid "Hintergrundbild wählen"
msgstr "Вибрати фонове зображення"

msgid "Bilder (PNG, JPG, WEBP …)"
msgstr "Зображення (PNG, JPG, WEBP …)"

msgid "Alle Dateien"
msgstr "Усі файли"

#, python-format
msgid ""
"Bild konnte nicht geladen werden:\n"
"%s"
msgstr ""
"Не вдалося завантажити зображення:\n"
"%s"

msgid "Bereit"
msgstr "Готово"

msgid "Deaktiviert / gestoppt"
msgstr "Вимкнено / зупинено"

msgid "Status unbekannt"
msgstr "Стан невідомий"

msgid "Nicht erreichbar (Timeout)"
msgstr "Недоступно (час вичерпано)"

