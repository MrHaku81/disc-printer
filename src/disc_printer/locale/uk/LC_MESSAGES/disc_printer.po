msgid ""
"Druckfehler:\n"
"%s"
msgstr ""
"Помилка друку:\n"
"%s"

msgid "Timeout: Drucker antwortet nicht (>30 s)."
msgstr "Час вичерпано: принтер не відповідає (>30 с)."

msgid "Druckauftrag gesendet"
msgstr "Завдання друку надіслано"

msgid "Druckauftrag erfolgreich in Warteschlange eingereiht."
msgstr "Завдання друку успішно додано до черги."
