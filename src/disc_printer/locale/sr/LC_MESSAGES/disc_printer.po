"Резолуција: %(px)d×%(px)d px  (300 DPI)\n"
"\n"
"%(cmd)s"

msgid "Drucken"
msgstr "Штампај"

#, python-format
msgid ""
"Render-Fehler:\n"
"%s"
msgstr ""
"Грешка рендеровања:\n"
"%s"

#, python-format
msgid ""
"Druckfehler:\n"
"%s"
msgstr ""
"Грешка штампања:\n"
"%s"

msgid "Timeout: Drucker antwortet nicht (>30 s)."
msgstr "Прекорачење времена: штампач не одговара (>30 s)."

msgid "Druckauftrag gesendet"
msgstr "Задатак штампања послат"

msgid "Druckauftrag erfolgreich in Warteschlange eingereiht."
msgstr "Задатак штампања успешно додат у ред чекања."
