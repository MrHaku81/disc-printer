"מדפסת:      %(name)s\n"
"רזולוציה:   %(px)d×%(px)d פיקסל  (300 DPI)\n"
"\n"
"%(cmd)s"

msgid "Drucken"
msgstr "הדפסה"

#, python-format
msgid ""
"Render-Fehler:\n"
"%s"
msgstr ""
"שגיאת עיבוד:\n"
"%s"

#, python-format
msgid ""
"Druckfehler:\n"
"%s"
msgstr ""
"שגיאת הדפסה:\n"
"%s"

msgid "Timeout: Drucker antwortet nicht (>30 s)."
msgstr "פסק זמן: המדפסת אינה מגיבה (>30 ש')."

msgid "Druckauftrag gesendet"
msgstr "משימת הדפסה נשלחה"

msgid "Druckauftrag erfolgreich in Warteschlange eingereiht."
msgstr "משימת ההדפסה נוספה לתור בהצלחה."
