msgstr "בחירת תמונת רקע"

msgid "Bilder (PNG, JPG, WEBP …)"
msgstr "תמונות (PNG, JPG, WEBP …)"

msgid "Alle Dateien"
msgstr "כל הקבצים"

#, python-format
msgid ""
"Bild konnte nicht geladen werden:\n"
"%s"
msgstr ""
"לא ניתן לטעון את התמונה:\n"
"%s"

